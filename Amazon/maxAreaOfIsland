func maxAreaOfIsland(grid [][]int) int {
    rows := len(grid)
    cols := len(grid[0])
    maxArea := 0

    var dfs func(int,int) int
    dfs = func(r,c int) int {
        // boundry and water check
        if r<0 || c<0 || r>=rows || c >= cols || grid[r][c] == 0 {
            return 0
        }
        // mark visited
        grid[r][c] = 0

        // current cell
        area := 1
        area += dfs(r+1, c)
        area += dfs(r-1, c)
        area += dfs(r, c+1)
        area += dfs(r, c-1)
        
        return area
    }

    for r:=0; r<rows; r++ {
        for c:=0; c<cols; c++ {
            if grid[r][c] == 1 {
                area := dfs(r,c)
                if area > maxArea {
                    maxArea = area
                }
            }
        }
    }
    return maxArea
}